---
interface NavLink { label: string; href: string }
interface CTA { label: string; href: string }
interface LogoProps { src: string; alt: string }

interface Props {
  logo: LogoProps;
  navLinks: NavLink[];
  cta?: CTA;
}

const { logo, navLinks, cta } = Astro.props;
---

<!-- Top contact strip -->
<div class="top-strip" id="topStrip">
  <a href="mailto:mx@jetavenue.net">mx@jetavenue.net</a>
  <a href="tel:8444805387">(844) 480-5387</a>
</div>

<!-- Main header -->
<header class="site-header" id="siteHeader">
  <div class="header-inner">
    <a href="/" class="header-logo-link">
      <img src={logo.src} alt={logo.alt} class="header-logo" />
    </a>

    <!-- Desktop nav -->
    <nav class="desktop-nav">
      {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      {cta && <a href={cta.href} class="nav-cta">{cta.label}</a>}
    </nav>

    <!-- Mobile hamburger -->
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Drawer overlay -->
<div class="drawer-overlay" id="drawerOverlay"></div>

<!-- Drawer — slides in from RIGHT -->
<div class="drawer" id="drawer">
  <button class="drawer-close" id="drawerClose" aria-label="Close menu">&times;</button>
  {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
  {cta && <a href={cta.href} class="drawer-cta">{cta.label}</a>}
  <div class="drawer-contact">
    <a href="mailto:mx@jetavenue.net">mx@jetavenue.net</a>
    <a href="tel:8444805387">(844) 480-5387</a>
  </div>
</div>

<style>
  /* ── Top strip ── */
  .top-strip {
    display: flex; align-items: center; justify-content: space-between;
    padding: 9px 20px;
    background: #fff;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-body); font-size: 13px;
    transition: max-height 0.3s ease, opacity 0.3s ease, padding 0.3s ease;
    overflow: hidden; max-height: 60px; opacity: 1;
  }
  .top-strip.hidden {
    max-height: 0; opacity: 0; padding-top: 0; padding-bottom: 0;
    border-bottom-color: transparent;
  }
  .top-strip a {
    text-decoration: none; color: var(--color-body);
  }
  .top-strip a:hover { color: var(--color-brand); }

  /* ── Main header ── */
  .site-header {
    position: sticky; top: 0; z-index: 200;
    background: #fff;
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px;
    max-width: 1200px; margin: 0 auto;
  }

  .header-logo-link { display: flex; align-items: center; }
  .header-logo { height: 28px; width: auto; display: block; }

  /* ── Desktop nav ── */
  .desktop-nav { display: none; }

  @media (min-width: 900px) {
    .header-logo { height: 36px; }
    .desktop-nav {
      display: flex; align-items: center; gap: 28px;
    }
    .desktop-nav a {
      text-decoration: none; color: var(--color-ink);
      font-family: var(--font-heading); font-size: 12px; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
    }
    .desktop-nav a:hover { color: var(--color-brand); }
    .nav-cta {
      background: var(--color-brand); color: #fff !important;
      padding: 10px 20px; border-radius: 3px;
      font-size: 12px !important; font-weight: 700 !important; letter-spacing: 0.06em !important;
      transition: background 0.18s;
    }
    .nav-cta:hover { background: var(--color-brand-dark) !important; }
  }

  /* ── Hamburger (three lines) ── */
  .hamburger {
    display: flex; flex-direction: column; justify-content: center;
    gap: 5px; background: none; border: none; cursor: pointer;
    padding: 6px; width: 36px; height: 36px;
  }
  .hamburger span {
    display: block; height: 2px; background: var(--color-ink);
    border-radius: 2px; transition: background 0.18s;
  }
  .hamburger:hover span { background: var(--color-brand); }

  @media (min-width: 900px) {
    .hamburger { display: none; }
  }

  /* ── Drawer (right side) ── */
  .drawer {
    position: fixed; top: 0; right: 0;
    width: 80vw; max-width: 320px; height: 100vh;
    background: #fff;
    padding: 28px 28px 28px;
    display: flex; flex-direction: column; gap: 0;
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.28s ease;
    box-shadow: -4px 0 24px rgba(0,0,0,0.12);
    z-index: 300;
  }
  .drawer.open { transform: translateX(0); }

  .drawer-close {
    position: absolute; top: 18px; right: 20px;
    background: none; border: none; cursor: pointer;
    font-size: 30px; line-height: 1; color: var(--color-ink);
    padding: 6px;
  }

  .drawer a {
    text-decoration: none; color: var(--color-ink);
    font-family: var(--font-heading); font-size: 16px; font-weight: 600;
    padding: 14px 0; border-bottom: 1px solid var(--color-border);
    letter-spacing: 0.02em;
  }
  .drawer a:last-of-type { border-bottom: none; }

  .drawer-cta {
    display: block; margin-top: 20px;
    background: var(--color-brand); color: #fff !important;
    padding: 13px 24px; border-radius: 3px; text-align: center;
    font-weight: 700 !important; font-size: 13px !important;
    border-bottom: none !important; letter-spacing: 0.05em;
  }

  .drawer-contact {
    margin-top: auto; padding-top: 24px;
    display: flex; flex-direction: column; gap: 8px;
    border-top: 1px solid var(--color-border) !important;
  }
  .drawer-contact a {
    font-size: 13px !important; font-weight: 400 !important;
    color: var(--color-body) !important; padding: 4px 0 !important;
    border-bottom: none !important; letter-spacing: 0 !important;
  }

  /* ── Overlay ── */
  .drawer-overlay {
    display: none; position: fixed; inset: 0;
    z-index: 150; background: rgba(0,0,0,0.35);
  }
  .drawer-overlay.open { display: block; }
</style>

<script>
  const hamburger   = document.getElementById('hamburger');
  const drawer      = document.getElementById('drawer');
  const overlay     = document.getElementById('drawerOverlay');
  const closeBtn    = document.getElementById('drawerClose');
  const topStrip    = document.getElementById('topStrip');

  function openDrawer() {
    drawer?.classList.add('open');
    overlay?.classList.add('open');
    document.getElementById('siteHeader')?.style.setProperty('z-index', '100');
    document.getElementById('topStrip')?.style.setProperty('z-index', '100');
  }
  function closeDrawer() {
    drawer?.classList.remove('open');
    overlay?.classList.remove('open');
    document.getElementById('siteHeader')?.style.removeProperty('z-index');
    document.getElementById('topStrip')?.style.removeProperty('z-index');
  }

  hamburger?.addEventListener('click', openDrawer);
  overlay?.addEventListener('click', closeDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  drawer?.querySelectorAll('a').forEach(l => l.addEventListener('click', closeDrawer));

  // Hide top strip on scroll
  let lastY = 0;
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y > 40) {
      topStrip?.classList.add('hidden');
    } else {
      topStrip?.classList.remove('hidden');
    }
    lastY = y;
  }, { passive: true });
</script>
